rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Helper function to get user data
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    // Helper function to check user role
    function hasRole(role) {
      return isAuthenticated() && getUserData().role == role;
    }
    
    // Users collection
    match /users/{userId} {
      // Users can read their own data
      allow read: if isAuthenticated() && request.auth.uid == userId;
      
      // Admins can read all users
      allow read: if hasRole('admin');
      
      // Admins can create/update users
      allow create, update: if hasRole('admin');
      
      // Users can update their own profile (limited fields)
      allow update: if isAuthenticated() && 
                       request.auth.uid == userId &&
                       !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'status', 'userId']);
    }
    
    // Leave Requests collection
    match /leaveRequests/{requestId} {
      // Students can read their own requests
      allow read: if isAuthenticated() && 
                     resource.data.studentId == request.auth.uid;
      
      // Students can create requests for themselves
      allow create: if isAuthenticated() && 
                       request.resource.data.studentId == request.auth.uid &&
                       request.resource.data.status == 'pending';
      
      // Students can update their own pending requests (edit or cancel)
      allow update: if isAuthenticated() && 
                       resource.data.studentId == request.auth.uid &&
                       resource.data.status == 'pending' &&
                       (request.resource.data.status == 'pending' || 
                        request.resource.data.status == 'cancelled');
      
      // Teachers can read requests assigned to them
      allow read: if isAuthenticated() && 
                     resource.data.teacherId == request.auth.uid;
      
      // Teachers can update status of their students' requests
      allow update: if isAuthenticated() && 
                       resource.data.teacherId == request.auth.uid &&
                       resource.data.status == 'pending' &&
                       (request.resource.data.status == 'approved' || 
                        request.resource.data.status == 'rejected');
      
      // Admins can read/write all leave requests
      allow read, write: if hasRole('admin');
    }
    
    // Notifications collection
    match /notifications/{notificationId} {
      // Users can read their own notifications
      allow read: if isAuthenticated() && 
                     resource.data.recipientId == request.auth.uid;
      
      // System can create notifications (any authenticated user)
      allow create: if isAuthenticated();
      
      // Users can update their own notifications (mark as read)
      allow update: if isAuthenticated() && 
                       resource.data.recipientId == request.auth.uid &&
                       request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
      
      // Admins can read all notifications
      allow read: if hasRole('admin');
    }
    
    // Attendance collection
    match /attendance/{attendanceId} {
      // Students can read their own attendance
      allow read: if isAuthenticated() && 
                     resource.data.studentId == request.auth.uid;
      
      // Teachers can read attendance for their classes
      allow read: if isAuthenticated() && 
                     resource.data.teacherId == request.auth.uid;
      
      // Teachers can create/update attendance for their classes
      allow create, update: if isAuthenticated() && 
                               request.resource.data.teacherId == request.auth.uid;
      
      // System can create attendance records (for approved leave)
      allow create, update: if isAuthenticated();
      
      // Admins can read/write all attendance
      allow read, write: if hasRole('admin');
    }
    
    // Classes collection
    match /classes/{classId} {
      // All authenticated users can read classes
      allow read: if isAuthenticated();
      
      // Teachers can read their own classes
      allow read: if isAuthenticated() && 
                     resource.data.teacherId == request.auth.uid;
      
      // Admins can create/update/delete classes
      allow write: if hasRole('admin');
    }
    
    // Enrollments collection
    match /enrollments/{enrollmentId} {
      // Students can read their own enrollments
      allow read: if isAuthenticated() && 
                     resource.data.studentId == request.auth.uid;
      
      // Teachers can read enrollments for their classes
      allow read: if isAuthenticated() && 
                     get(/databases/$(database)/documents/classes/$(resource.data.classId)).data.teacherId == request.auth.uid;
      
      // Admins can read/write all enrollments
      allow read, write: if hasRole('admin');
    }
    
    // Attendance Sessions collection
    match /attendanceSessions/{sessionId} {
      // Teachers can read their own sessions
      allow read: if isAuthenticated() && 
                     resource.data.teacherId == request.auth.uid;
      
      // Teachers can create/update their own sessions
      allow create, update: if isAuthenticated() && 
                               request.resource.data.teacherId == request.auth.uid;
      
      // Admins can read/write all sessions
      allow read, write: if hasRole('admin');
    }
    
    // Counters collection (for auto-increment IDs)
    match /counters/{counterId} {
      // Only admins and system can read/write counters
      allow read, write: if hasRole('admin');
      
      // Allow system operations (for user creation)
      allow read, write: if isAuthenticated();
    }
    
    // Attendance Broadcasts collection
    match /attendanceBroadcasts/{broadcastId} {
      // All authenticated users can read broadcasts
      allow read: if isAuthenticated();
      
      // Teachers can create broadcasts
      allow create: if isAuthenticated() && hasRole('teacher');
      
      // Admins can read/write all broadcasts
      allow read, write: if hasRole('admin');
    }
  }
}
